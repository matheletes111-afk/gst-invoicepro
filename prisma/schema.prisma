model InventoryMaster {
  id              Int      @id @default(autoincrement())
  
  // Goods or Service reference
  goods_id        Int?     // Reference to GoodsCatalog
  service_id      Int?     // Reference to ServiceCatalog
  
  // Unit of measurement
  unit_id         Int      // Unit of Measurement
  
  // Inventory details
  price           Decimal  @db.Decimal(10, 2)  // Current price per unit
  qty             Decimal  @db.Decimal(10, 2)  // Current quantity in stock
  inventory_amount Decimal @db.Decimal(10, 2)  // Current inventory value (price * qty)
  
  
  // Organization
  organization_id Int
  
  // Timestamps
  created_by Int?
  updated_by Int?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  
  // Relations
  goods           GoodsCatalog?    @relation(fields: [goods_id], references: [goodsId])
  service         ServiceCatalog?  @relation(fields: [service_id], references: [service_id])
  unit            Unit             @relation(fields: [unit_id], references: [id])
  organization    Organization     @relation(fields: [organization_id], references: [id])
  
  // Indexes for better performance
  @@index([goods_id])
  @@index([service_id])
  @@index([unit_id])
  @@index([organization_id])
  // Ensure either goods_id or service_id is set (but not both)
  @@map("tbl_inventory_master")
}







