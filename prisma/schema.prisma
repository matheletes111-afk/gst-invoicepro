enum AdjustmentType {
  DEBIT
  CREDIT
  NONE
}


model Adjustment {
  adjustment_id Int @id @default(autoincrement())
  adjustment_note_no       String      @db.VarChar(200)
  date                     DateTime    @db.Date
  organization_id          Int
  customer_id              Int?
  sale_id               Int?
  invoice_no               String       @db.VarChar(200)
  sales_amount Decimal @db.Decimal(10, 2) ///("addition of exempt and taxable")
  exempt_amount  Decimal  @db.Decimal(10, 2)
  taxable_amount Decimal  @db.Decimal(10, 2)
  gst_amount Decimal @db.Decimal(10, 2) @default(0) ///("5% of taxable")
  total_invoice_amount Decimal @db.Decimal(10, 2) @default(0) ///("Sum of exempt amount, taxable amount, and GST amount")
  total_adjustment_amount  Decimal      @db.Decimal(10, 2)
  effect_on_gst_payable    Decimal      @db.Decimal(10, 2) @default(0)
  status SalesStatus @default(IP)
  created_by Int
  created_on DateTime @db.Date
  remark String @db.Text
  adjustment_type  AdjustmentType  @default(NONE)
  adjustment_amount     Decimal       @db.Decimal(10, 2)


  // Relations
  customer      Party?        @relation(fields: [customer_id], references: [partyId])
  organization  Organization  @relation(fields: [organization_id], references: [id])
  invoice       Sales?        @relation(fields: [sale_id], references: [sales_id])


  adjustmentItems AdjustmentItem[]

  @@map("tbl_adjustment")
}

model AdjustmentItem {
  adjustment_item_id Int @id @default(autoincrement())
  adjustment_id       Int
  sales_item_type        SalesItemType


  // Separate fields for goods and service
  goods_id      Int?  // when type = GOODS
  service_id    Int?  // when type = SERVICE

  goods_service_name     String?       @db.VarChar(500)
  goods_service_description    String?       @db.VarChar(2500)
  unit_of_measurement_id Int

  unit_price                 Decimal @db.Decimal(10, 2)
  quantity                   Decimal @db.Decimal(10, 2)
  amount                     Decimal @db.Decimal(10, 2)
  discount                   Decimal @db.Decimal(10, 2)
  amount_after_discount      Decimal @db.Decimal(10, 2)
  gst_amount                 Decimal @db.Decimal(10, 2)
  gst_percentage             String?       @db.VarChar(500)
  goods_service_total_amount Decimal @db.Decimal(10, 2)  ///("refer as payable amount")
  reason_for_adjustment String?      @db.VarChar(1000)
  adjustment_type       AdjustmentType
  adjustment_amount     Decimal       @db.Decimal(10, 2)
  created_by Int
  created_on DateTime @db.Date
  
  // Relations
  adjustment Adjustment @relation(fields: [adjustment_id], references: [adjustment_id], onDelete: Cascade)
  goods      GoodsCatalog?   @relation("GoodsAdjustmentItems", fields: [goods_id], references: [goodsId], map: "fk_adjustmentitem_goods")

  service    ServiceCatalog? @relation("ServiceAdjustmentItems", fields: [service_id], references: [service_id], map: "fk_adjustmentitem_service")

  unitObject Unit @relation(fields: [unit_of_measurement_id], references: [id], map: "fk_adjustmentitem_unit")


  @@map("tbl_adjustment_items")
