enum PurchaseItemType {
  GOODS
  SERVICE
}


enum PurchaseStatus{
  O
  C
}

model Purchase {
  purchase_id Int @id @default(autoincrement())

  organization_id Int
  supplier_id     Int
  dealer_id       Int?
  currency        Int

  purchase_date     DateTime @db.Date
  purchase_order_no String   @db.VarChar(50)

  sales_amount Decimal @db.Decimal(10, 2) ///("addition of exempt and taxable")
  exempt_amount  Decimal  @db.Decimal(10, 2)
  taxable_amount Decimal  @db.Decimal(10, 2)
  gst_amount Decimal @db.Decimal(10, 2) @default(0) ///("5% of taxable")
  total_invoice_amount Decimal @db.Decimal(10, 2) @default(0) 
  purchase_status PurchaseStatus @default(O)

  created_by Int
  created_on DateTime @db.Date
  
  payment_mode    PaymentMode?

  // Payment Gateway
  transaction_id  String?      @db.VarChar(100)
  
  // mBOB, mPAY, TPay, DrukPay, ePay, DK Bank
  journal_number  String?      @db.VarChar(50)
  
  // Cheque
  cheque_number   String?      @db.VarChar(50)
  bank_name       String? 


  // Relations
  items         PurchaseItem[]
  organization  Organization    @relation(fields: [organization_id], references: [id])
  supplier      SupplierMaster  @relation("PurchaseSupplier", fields: [supplier_id], references: [supplierId])
  dealer        DealerMaster?   @relation("PurchaseDealer", fields: [dealer_id], references: [dealerId])
  currency_info Currency        @relation(fields: [currency], references: [currencyId])

  @@map("tbl_purchase")
}



model PurchaseItem {
  purchase_item_id Int @id @default(autoincrement())
