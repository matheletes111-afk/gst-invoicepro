// prisma/schema.prisma

model Role {
  id              Int       @id @default(autoincrement())
  roleName        String    @unique
  roleDescription String?
  status          String    @default("A") // A=Active, I=Inactive
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  permissions     RoleToPermission[]

  @@map("roles")
}

model RoleToPermission {
  id              Int       @id @default(autoincrement())
  roleId          Int
  menuId          String    // References MenuMaster.id

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  role            Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  menu            MenuMaster  @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@unique([roleId, menuId])
  @@map("role_to_permissions")
}

// Your existing MenuModules and MenuMaster models remain the same
model MenuModules {
  id               String    @id @default(cuid())
  moduleName       String    @unique
  moduleDescription String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  menus            MenuMaster[]

  @@map("menu_modules")
}

model MenuMaster {
  id              String    @id @default(cuid())
  moduleId        String
  menuName        String
  menuDescription String?
  menuEndPoint    String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  module          MenuModules @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  rolePermissions RoleToPermission[]

  @@unique([moduleId, menuName])
  @@map("menu_master")
}